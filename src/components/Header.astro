---
import { asset } from "../lib/asset";

const nav = [
  { label: "Articles", href: "/articles/" },
  { label: "About", href: "/about/" },
];
const cms = import.meta.env.DEV ? "/keystatic" : null;
---

<header class="sticky top-0 z-50 border-b border-line bg-paper/90 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5">
    <a href="/" class="flex items-center">
      <img
        src={asset("images/geekienews-logo.png")}
        alt="GeekieNews"
        width="1972"
        height="600"
        class="brand-logo"
      />
    </a>

    <nav class="hidden items-center gap-8 md:flex">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm font-medium text-muted transition-colors hover:text-brand"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      {
        cms && (
          <a
            href={cms}
            class="hidden font-mono text-xs tracking-wide text-faint uppercase transition-colors hover:text-brand sm:inline"
            >CMS</a
          >
        )
      }
      <a
        href="https://github.com/nugehs/geekienews"
        class="inline-flex items-center gap-1.5 rounded-lg bg-brand px-4 py-2 text-sm font-semibold text-paper transition-transform hover:-translate-y-0.5"
      >
        GitHub
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</header>
