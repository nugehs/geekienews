---
import Layout from "./Layout.astro";
import { render, type CollectionEntry } from "astro:content";
import { slugFromId } from "../lib/articles";

interface Props {
  article: CollectionEntry<"articles">;
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, description, publishDate, author, category, tags } = article.data;
const slug = slugFromId(article.id);

const formattedDate = publishDate.toLocaleDateString("en-GB", {
  day: "numeric",
  month: "long",
  year: "numeric",
});

const canonical = new URL(`/articles/${slug}/`, Astro.site).href;
---

<Layout
  title={`${title} — GeekieNews`}
  description={description}
  canonical={canonical}
  ogType="article"
>
  <article class="mx-auto max-w-3xl px-5 py-14">
    <header class="border-b border-line pb-10">
      <p class="kicker text-accent">{category}</p>
      <h1 class="font-display mt-4 text-4xl font-bold tracking-tight text-ink md:text-5xl">
        {title}
      </h1>
      <p class="mt-5 text-lg leading-relaxed text-muted">{description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-faint">
        <span>{author}</span>
        <span aria-hidden="true">·</span>
        <time datetime={publishDate.toISOString()}>{formattedDate}</time>
      </div>
      {
        tags.length > 0 && (
          <ul class="mt-5 flex flex-wrap gap-2">
            {tags.map((tag) => (
              <li>
                <a
                  href={`/tags/${tag}/`}
                  class="rounded-full border border-line bg-card px-3 py-1 font-mono text-xs text-muted transition-colors hover:border-accent hover:text-accent"
                >
                  {tag}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </header>

    <div class="prose-news mt-10">
      <Content />
    </div>
  </article>
</Layout>
