---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { asset } from "../lib/asset";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogType?: "website" | "article";
}

const {
  title = "GeekieNews | static analysis, never the model",
  description = "Essays, audits, and releases on AI software reliability. When AI writes code, static analysis watches the AI.",
  ogType = "website",
} = Astro.props;

const canonicalUrl = Astro.props.canonical ?? Astro.url.href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href={asset("icon.png")} />
    <link rel="apple-touch-icon" href={asset("icon.png")} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#004795" />
    <meta property="og:image" content={new URL(asset("images/geekienews-logo.png"), Astro.site).href} />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="GeekieNews" />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="alternate" type="application/rss+xml" title="GeekieNews" href={asset("rss.xml")} />
  </head>
  <body class="min-h-screen antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
